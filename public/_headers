/*
  # HSTS - Force HTTPS for 1 year (fixes Google password warning)
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  
  # Content Security Policy - Prevent injection attacks
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://cdn.skoolar.org; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data: https:; connect-src 'self' https:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
  
  # Prevent browsers from MIME-sniffing
  X-Content-Type-Options: nosniff
  
  # Prevent clickjacking
  X-Frame-Options: DENY
  
  # XSS Protection (legacy)
  X-XSS-Protection: 1; mode=block
  
  # Referrer Policy
  Referrer-Policy: strict-origin-when-cross-origin
  
  # Permissions Policy (Permissions-Policy header)
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  
  # CT Enforcement - Require Certificate Transparency
  Expect-CT: max-age=86400, enforce
  
  # No cross-domain requests
  X-Permitted-Cross-Domain-Policies: none
